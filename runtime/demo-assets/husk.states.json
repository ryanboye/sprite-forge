    "attack": { "frames": ["idle", "attack"], "fps": 8,  "next": "walk", "events": { "1": "dealDamage" } },
    "pain":   { "frames": ["idle"],           "fps": 12, "next": "@prev", "interrupts": true },
    "death":  { "frames": ["dead"],           "fps": 6,  "next": "corpse", "locked": true },
    "corpse": { "frames": ["dead"],           "fps": 0,  "locked": true }
  }
